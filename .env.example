# Database
DB_URL=postgresql+asyncpg://user:password@localhost:5432/genset_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
DEBUG=true
LOG_LEVEL=INFO

# Business rules
MIN_PAUSE_BETWEEN_STARTS_MINUTES=15
STALE_SHIFT_HOURS=12
AUTO_CLOSE_STALE_SHIFTS=false
