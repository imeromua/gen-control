# База даних
DB_URL=postgresql+asyncpg://user:password@localhost:5432/genset_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Безпека
SECRET_KEY=your-secret-key-min-32-chars-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Режим
DEBUG=true
ENVIRONMENT=development

# Бізнес-логіка
MIN_PAUSE_BETWEEN_STARTS_MINUTES=15
STALE_SHIFT_HOURS=12
AUTO_CLOSE_STALE_SHIFTS=false
