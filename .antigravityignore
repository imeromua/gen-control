# ==========================================
# Оптимізований .antigravityignore
# ==========================================

# 1. Віртуальні середовища та залежності (КРИТИЧНО ДЛЯ ЕКОНОМІЇ ТОКЕНІВ)
# Агенту ніколи не потрібно читати вихідний код встановлених бібліотек. 
# Для розуміння залежностей йому достатньо файлу pyproject.toml
.venv/
venv/
env/
Lib/
Scripts/
Include/

# 2. Кеш Python та інструментів
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.uv_cache/
.coverage
htmlcov/

# 3. Бази даних та логи
# Агент може зависнути або витратити весь ліміт, намагаючись прочитати бінарник БД або лог на 50 МБ
*.sqlite3
*.db
*.log
logs/

# 4. Зібрані пакети та дистрибутиви
build/
dist/
*.egg-info/
*.egg
*.whl

# 5. Системні файли та налаштування IDE
.git/
.svn/
.vscode/
.idea/
.DS_Store
Thumbs.db

# 6. Важкі медіафайли та документи
# Агенту не потрібно читати байти картинок
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.pdf
*.mp4
*.mp3
*.wav

# 7. Тимчасові файли (опціонально, але корисно)
tmp/
temp/